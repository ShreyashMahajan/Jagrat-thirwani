# Copy to .env.local and fill in.

# Where contact form submissions are sent
CONTACT_EMAIL=your@email.com

# Optional: for real email delivery via Resend (https://resend.com)
# RESEND_API_KEY=re_xxxx

# Optional: Google Analytics, Meta Pixel — wire in src/lib/analytics.ts and layout
# NEXT_PUBLIC_GA_ID=G-xxxx
# NEXT_PUBLIC_META_PIXEL_ID=xxxx
